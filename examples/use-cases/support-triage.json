  "edges": [
    {
      "source": "submitTicket",
      "target": "classifyTicket"
    },
    {
      "source": "classifyTicket",
      "target": "routeTicket"
    },
    {
      "source": "routeTicket",
      "target": "tier1Resolve"
    },
    {
      "source": "tier1Resolve",
      "target": "tier2Resolve"
    },
    {
      "source": "tier1Resolve",
      "target": "followUp"
    },
    {
      "source": "tier2Resolve",
      "target": "followUp"
    },
    {
      "source": "followUp",
      "target": "routeTicket"
    }
  ]
}
